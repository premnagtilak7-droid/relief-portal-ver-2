{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "volunteer", "victim"] },
        "photoURL": { "type": "string", "format": "url" },
        "phoneNumber": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "availableForRescue": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["pending", "verified", "rejected", "none"] },
        "verificationDocURL": { "type": "string" },
        "verificationNotes": { "type": "string" },
        "idConfidenceScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "SOSAlert": {
      "title": "SOSAlert",
      "description": "Emergency request for aid",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "emergencyType": { "type": "string" },
        "description": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "acknowledged", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/alerts/{alertId}": {
      "schema": "SOSAlert",
      "description": "Emergency alerts"
    }
  }
}
